# App
APP_NAME=Meeting Room Booking
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# PostgreSQL
# For local execution outside Docker, keep localhost.
# Inside docker-compose the backend and worker override the host to `postgres`.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meeting_room_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public

# SQLAlchemy / FastAPI
# For local execution outside Docker, keep localhost.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meeting_room_booking

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_DELAY_SECONDS=30

# Mailer
# For local execution outside Docker, keep localhost:1025 if you are using MailHog.
# In docker-compose the worker overrides the host to `mailhog`.
MAILER_FROM_EMAIL=no-reply@meeting-room-booking.local
MAILER_PROVIDER=smtp
MAILER_SMTP_HOST=localhost
MAILER_SMTP_PORT=1025
MAILER_SMTP_USERNAME=
MAILER_SMTP_PASSWORD=
MAILER_SMTP_USE_TLS=false
MAILER_SMTP_USE_SSL=false
MAILER_SMTP_TIMEOUT_SECONDS=10

# Seed
INITIAL_USER_EMAIL=admin@meetingroom.local
INITIAL_USER_FULL_NAME=Admin User
INITIAL_USER_PASSWORD=123@mudar

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api/v1
